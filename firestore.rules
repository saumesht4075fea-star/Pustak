rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // User: { uid, email, displayName, photoURL, role, createdAt }
    // Ebook: { id, title, author, description, price, coverUrl, fileUrl, category, createdAt }
    // Order: { id, userId, ebookId, amount, currency, status, paymentId, createdAt }
    // Review: { id, userId, userName, ebookId, rating, comment, createdAt }
    // Wishlist: { userId, ebookId, createdAt }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
         request.auth.token.email == "saumesht4075fea@gmail.com" && 
         request.auth.token.email_verified == true;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'customer'];
    }

    function isValidEbook(data) {
      return data.keys().hasAll(['title', 'author', 'price', 'coverUrl']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.author is string && data.author.size() > 0 &&
             data.price is number && data.price >= 0 &&
             data.coverUrl is string && data.coverUrl.matches("^https?://.*");
    }

    function isValidReview(data) {
      return data.keys().hasAll(['userId', 'ebookId', 'rating']) &&
             data.userId == request.auth.uid &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             (!('comment' in data) || (data.comment is string && data.comment.size() < 1000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.role == resource.data.role; // Role cannot be changed by user
      allow update: if isAdmin();
    }

    match /ebooks/{ebookId} {
      allow read: if true;
      allow write: if isAdmin() && isValidEbook(request.resource.data);
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidReview(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /wishlist/{wishlistId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
